# Database — SQLite (development) or PostgreSQL (production)
DATABASE_URL="file:./dev.db"
# DATABASE_URL="postgresql://legal:STRONG_PASSWORD@localhost:5432/legaldb"

# NextAuth
NEXTAUTH_SECRET="change-me-to-a-random-secret-at-least-32-chars"
NEXTAUTH_URL="https://www.dadparvaran.com"

# Upload
UPLOAD_DIR="./public/uploads"
MAX_FILE_SIZE="10485760"

# Domain
SITE_URL="https://www.dadparvaran.com"

# Google Search Console HTML-tag verification (content value only)
GOOGLE_SITE_VERIFICATION=

# Analytics. Both trackers run independently — either can be blank.
# GA4 script is fetched from googletagmanager.com and blocked for many
# visitors inside Iran, so Umami (self-hosted at /umami, same-origin) is
# the reliable source for that audience.
NEXT_PUBLIC_GA_ID=
NEXT_PUBLIC_UMAMI_WEBSITE_ID=

# Bale messenger — bot token used by both the operational admin channel
# (contact-form notifications) AND the consultation intake pipeline below.
# api.telegram.org is unreachable from the production host; tapi.bale.ai is.
# Get the token from @botfather inside Bale; message your own bot to find
# BALE_ADMIN_CHAT_ID via `npm run bale:get-updates`. Without the token
# every Bale integration is silently skipped and the app still works.
BALE_BOT_TOKEN=
BALE_ADMIN_CHAT_ID=

# ─── Bale consultation distribution ──────────────────────────────────────
# Users click "درخواست مشاوره در بله", complete a Bale Mini App form, and
# their (low-info) request is fanned out to a private lawyers group. First
# lawyer to click "پذیرش" atomically claims it.
BALE_BOT_PUBLIC_URL="https://ble.ir/YOUR_BOT_USERNAME"
NEXT_PUBLIC_BALE_BOT_URL="https://ble.ir/YOUR_BOT_USERNAME"
BALE_LAWYERS_GROUP_CHAT_ID=
BALE_WEBHOOK_PATH_SECRET=
BALE_MINIAPP_URL="https://www.dadparvaran.com/fa/bale/consultation"
BALE_API_BASE_URL="https://tapi.bale.ai"
BALE_REQUEST_TIMEOUT_MS="8000"
BALE_MINIAPP_MAX_AGE_SECONDS="600"
# HMAC_MODE lives here because Bale's docs are ambiguous about the HMAC
# argument order. "compatible" accepts both docs and telegram-style
# signatures; after a live signature test, lock this down to whichever
# is correct in production.
BALE_MINIAPP_HMAC_MODE="compatible"

# Seed passwords. If unset, `npx tsx prisma/seed.ts` generates random ones and
# prints them once — never commit real values here.
SEED_ADMIN_PASSWORD=
SEED_LAWYER_PASSWORD=
