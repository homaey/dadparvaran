generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ─── کاربران (ادمین و وکلا) ────────────────────────────────────────────────

model User {
  id            String      @id @default(cuid())
  name          String
  email         String      @unique
  phone         String?     @unique
  password      String
  role          String      @default("LAWYER")
  avatar        String?
  emailVerified DateTime?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  baleId        String?  @unique

  teamMember TeamMember?

  // --- content-management relations ---
  assignedTasks          Task[]                 @relation("Assignee")
  createdTasks           Task[]                 @relation("Creator")
  reviewTasks            Task[]                 @relation("Reviewer")
  contentArticles        ContentArticle[]
  contentPlans           ContentPlan[]          @relation("PlanCreator")
  calendarItems          ContentCalendarItem[]  @relation("CalendarAssignee")
  notifications          Notification[]
  taskActivities         TaskActivity[]
  approvedQualityReviews ArticleQualityReview[] @relation("QualityApprover")
}

// ─── اعضای تیم (ادغام Lawyer + TeamMember) ─────────────────────────────────

model TeamMember {
  id               Int      @id @default(autoincrement())
  nameFA           String
  nameEN           String
  slug             String   @unique
  roleFA           String
  roleEN           String
  bioFA            String
  bioEN            String
  photoUrl         String?
  barNumber        String?  @unique
  experience       Int      @default(0)
  education        String?
  phone            String?
  licenseImage     String?
  isAvailable      Boolean  @default(true)
  isActive         Boolean  @default(true)
  status           String   @default("APPROVED")
  order            Int      @default(0)
  userId           String?  @unique
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user                  User?                       @relation(fields: [userId], references: [id], onDelete: SetNull)
  articles              Article[]
  baleAccount           LawyerBaleAccount?
  assignedConsultations ConsultationRequest[]       @relation("AssignedLawyer")
  baleActivationCodes   LawyerBaleActivationCode[]
}

// ─── مقالات ────────────────────────────────────────────────────────────────

model Category {
  id       String    @id @default(cuid())
  nameFA   String
  nameEN   String
  slug     String    @unique
  articles Article[]
}

model Article {
  id          Int       @id @default(autoincrement())
  authorId    Int
  categoryId  String?
  title       String
  slug        String    @unique
  excerpt     String?
  blocks      String    @default("[]")
  coverImage  String?
  status      String    @default("DRAFT")
  readTimeMin Int       @default(5)
  viewCount   Int       @default(0)
  priority    Int       @default(0)
  scheduledAt DateTime?
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  author         TeamMember      @relation(fields: [authorId], references: [id])
  category       Category?       @relation(fields: [categoryId], references: [id])
  contentArticle ContentArticle?
}

// ─── قوانین و مقررات ───────────────────────────────────────────────────────

model LegalNode {
  id                Int         @id @default(autoincrement())
  parentId          Int?
  parent            LegalNode?  @relation("NodeHierarchy", fields: [parentId], references: [id])
  children          LegalNode[] @relation("NodeHierarchy")
  type              String
  title             String
  slug              String
  lawKey            String?     @unique
  lawId             Int?
  articleNumber     String?
  content           String?
  orderIndex        Int         @default(0)
  adoptionDate      String?
  adoptionAuthority String?
  sourceUrl         String?
  isRepealed        Boolean     @default(false)
  lastAmendedAt     DateTime?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  relatedRulings NodeRelatedRuling[]

  @@unique([parentId, slug])
}

// ─── آرای وحدت رویه و نظریات مشورتی ───────────────────────────────────────

model Ruling {
  id           Int                 @id @default(autoincrement())
  kind         String
  number       String
  date         String
  summary      String
  fullText     String?
  sourceUrl    String?
  relatedNodes NodeRelatedRuling[]
}

model NodeRelatedRuling {
  legalNodeId Int
  legalNode   LegalNode @relation(fields: [legalNodeId], references: [id])
  rulingId    Int
  ruling      Ruling    @relation(fields: [rulingId], references: [id])

  @@id([legalNodeId, rulingId])
}

// ─── تگ‌ها (سیستم مشترک) ──────────────────────────────────────────────────

model Tag {
  id          Int        @id @default(autoincrement())
  category    String
  nameFA      String
  nameEN      String
  slug        String     @unique
  description String?
  taggables   Taggable[]
}

model Taggable {
  tagId        Int
  tag          Tag    @relation(fields: [tagId], references: [id])
  taggableType String // LEGAL_NODE | TEAM_MEMBER | ARTICLE
  taggableId   Int

  @@id([tagId, taggableType, taggableId])
}

// ─── ماشین‌حساب‌ها ──────────────────────────────────────────────────────────

model Calculator {
  id            Int     @id @default(autoincrement())
  slug          String  @unique
  titleFA       String
  titleEN       String
  descriptionFA String?
  descriptionEN String?
  isPublished   Boolean @default(false)
  inputsSchema  String?
  order         Int     @default(0)
}

// ─── شاخص بها (تورم) ─────────────────────────────────────────────────────

model PriceIndex {
  id          Int       @id @default(autoincrement())
  jalaliYear  Int
  jalaliMonth Int       @default(0) // 0 = سالانه, 1-12 = ماهانه
  value       Float
  sourceTitle String?
  sourceUrl   String?
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([jalaliYear, jalaliMonth])
}

// ─── نرخ دیه ──────────────────────────────────────────────────────────────

model DiyeRate {
  id          Int       @id @default(autoincrement())
  jalaliYear  Int       @unique
  amount      BigInt
  sourceTitle String?
  sourceUrl   String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

// ─── مهلت‌های قضایی ──────────────────────────────────────────────────────────

model LegalDeadline {
  id          Int     @id @default(autoincrement())
  category    String  // civil | executionCivil | criminal
  title       String
  days        Int
  foreignDays Int?
  article     String?
  defaultMode String? // "minimum" for minimum-gap deadlines
  orderIndex  Int     @default(0)
  isActive    Boolean @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([category, title])
}

// ─── تعطیلات رسمی ───────────────────────────────────────────────────────────

model Holiday {
  id          Int     @id @default(autoincrement())
  jalaliYear  Int
  jalaliMonth Int
  jalaliDay   Int
  title       String?
  isFixed     Boolean @default(false) // true = تعطیلات ثابت شمسی
  createdAt   DateTime @default(now())

  @@unique([jalaliYear, jalaliMonth, jalaliDay])
}

// ─── پیام‌های تماس ──────────────────────────────────────────────────────────

model ContactMessage {
  id        Int      @id @default(autoincrement())
  name      String
  phone     String?
  email     String
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
}

// ─── تنظیمات سایت ──────────────────────────────────────────────────────────

model SiteSettings {
  id        String   @id @default("singleton")
  data      String   @default("{}")
  updatedAt DateTime @updatedAt
}

// ─── دسته‌بندی اوراق قضایی (درخت‌واره موضوعی) ─────────────────────────────

model LegalFormCategory {
  id          Int                 @id @default(autoincrement())
  parentId    Int?
  parent      LegalFormCategory?  @relation("FormCatHierarchy", fields: [parentId], references: [id])
  children    LegalFormCategory[] @relation("FormCatHierarchy")
  nameFA      String
  nameEN      String              @default("")
  slug        String              @unique
  descFA      String              @default("")
  descEN      String              @default("")
  icon        String?
  order       Int                 @default(0)
  templates   LegalFormTemplate[]

  @@unique([parentId, slug])
}

// ─── نمونه اوراق قضایی ─────────────────────────────────────────────────────

model LegalFormTemplate {
  id          Int                @id @default(autoincrement())
  slug        String             @unique
  categoryId  Int?
  category    LegalFormCategory? @relation(fields: [categoryId], references: [id])
  docType     String             // petition | complaint | declaration | appeal
  titleFA     String
  titleEN     String             @default("")
  descFA      String             @default("")
  descEN      String             @default("")
  content     String             @default("") // HTML body of the form document
  isPublished Boolean            @default(true)
  order       Int                @default(0)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
}

// =========================================================================
// CONTENT-MANAGEMENT MODELS
// =========================================================================

model ContentPlan {
  id               Int                   @id @default(autoincrement())
  title            String
  periodStart      DateTime
  periodEnd        DateTime
  articleCount     Int
  goal             String
  targetAudience   String
  legalServices    String
  priorityAreas    String
  status           String                @default("DRAFT")
  typeDistribution String?
  aiModel          String?
  createdById      String
  createdAt        DateTime              @default(now())
  createdBy        User                  @relation("PlanCreator", fields: [createdById], references: [id], onDelete: Restrict)
  items            ContentCalendarItem[]

  @@index([createdById, createdAt])
}

model ContentCalendarItem {
  id               Int        @id @default(autoincrement())
  contentPlanId    Int
  title            String
  articleType      String
  legalCategory    String
  keyword          String
  searchIntent     String
  targetAudience   String
  popularityScore  Int
  businessScore    Int
  seoScore         Int
  educationalScore Int
  priorityScore    Float
  assignedUserId   String?
  deadline         DateTime
  status           String     @default("PROPOSED")
  taskId           Int?       @unique
  contentPlan      ContentPlan @relation(fields: [contentPlanId], references: [id], onDelete: Cascade)
  assignedUser     User?       @relation("CalendarAssignee", fields: [assignedUserId], references: [id], onDelete: SetNull)
  task             Task?       @relation(fields: [taskId], references: [id], onDelete: SetNull)

  @@index([contentPlanId, deadline])
  @@index([priorityScore])
}

model SystemSetting {
  id    Int    @id @default(autoincrement())
  key   String @unique
  value String
}

model Task {
  id             Int        @id @default(autoincrement())
  title          String
  description    String?
  status         String     @default("PLANNED")
  deadline       DateTime?
  assigneeId     String
  reviewerId     String?
  creatorId      String
  draftContent   String?
  reviewFeedback String?
  submittedAt    DateTime?
  approvedAt     DateTime?
  publishedAt    DateTime?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  assignee       User                 @relation("Assignee", fields: [assigneeId], references: [id], onDelete: Restrict)
  reviewer       User?                @relation("Reviewer", fields: [reviewerId], references: [id], onDelete: SetNull)
  creator        User                 @relation("Creator", fields: [creatorId], references: [id], onDelete: Restrict)
  article        ContentArticle?
  calendarItem   ContentCalendarItem?
  notifications  Notification[]
  activities     TaskActivity[]

  @@index([assigneeId, status])
  @@index([reviewerId, status])
  @@index([deadline])
}

model TaskActivity {
  id         Int      @id @default(autoincrement())
  taskId     Int
  userId     String
  fromStatus String?
  toStatus   String
  note       String?
  createdAt  DateTime @default(now())
  task       Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user       User @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@index([taskId, createdAt])
}

model Notification {
  id           Int      @id @default(autoincrement())
  userId       String
  taskId       Int?
  type         String
  channel      String   @default("IN_APP")
  status       String   @default("PENDING")
  title        String
  message      String
  scheduledFor DateTime
  sentAt       DateTime?
  readAt       DateTime?
  dedupeKey    String   @unique
  createdAt    DateTime @default(now())
  user         User @relation(fields: [userId], references: [id], onDelete: Cascade)
  task         Task? @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([userId, status, scheduledFor])
}

model ContentArticle {
  id                 Int      @id @default(autoincrement())
  title              String
  body               String   @default("")
  status             String   @default("DRAFT")
  authorId           String
  taskId             Int?     @unique
  templateKey        String?
  coverImage         String?
  imageGuidance      String?
  publishedArticleId Int?     @unique
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  author             User                    @relation(fields: [authorId], references: [id], onDelete: Restrict)
  task               Task?                   @relation(fields: [taskId], references: [id], onDelete: SetNull)
  publishedArticle   Article?                @relation(fields: [publishedArticleId], references: [id], onDelete: SetNull)
  blocks             ArticleBlock[]
  qualityReviews     ArticleQualityReview[]
  exportProfile      ArticleExportProfile?

  @@index([status])
}

model ArticleExportProfile {
  id               Int      @id @default(autoincrement())
  articleId        Int      @unique
  slug             String   @unique
  service          String
  keywords         String
  metaTitle        String
  metaDescription  String
  imageDescription String
  imagePrompt      String
  altText          String
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  article          ContentArticle @relation(fields: [articleId], references: [id], onDelete: Cascade)
}

model ArticleQualityReview {
  id               Int      @id @default(autoincrement())
  articleId        Int
  status           String   @default("AI_REVIEWED")
  legalScore       Int
  seoScore         Int
  readabilityScore Int
  legalSummary     String
  seoSummary       String
  legalFindings    String
  seoFindings      String
  metaDescription  String?
  contentSignature String
  model            String
  humanNote        String?
  approvedById     String?
  approvedAt       DateTime?
  createdAt        DateTime @default(now())
  article          ContentArticle @relation(fields: [articleId], references: [id], onDelete: Cascade)
  approvedBy       User?          @relation("QualityApprover", fields: [approvedById], references: [id], onDelete: SetNull)

  @@index([articleId, createdAt])
}

model ArticleBlock {
  id            Int      @id @default(autoincrement())
  articleId     Int
  key           String
  label         String
  content       String   @default("")
  position      Int
  version       Int      @default(1)
  generatedByAi Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  article       ContentArticle           @relation(fields: [articleId], references: [id], onDelete: Cascade)
  generations   ArticleBlockGeneration[]

  @@unique([articleId, key])
  @@index([articleId, position])
}

model ArticleBlockGeneration {
  id              Int      @id @default(autoincrement())
  blockId         Int
  operation       String
  model           String
  previousContent String?
  resultContent   String
  createdAt       DateTime @default(now())
  block           ArticleBlock @relation(fields: [blockId], references: [id], onDelete: Cascade)

  @@index([blockId, createdAt])
}

// ─── Bale consultation intake and lawyer handoff ─────────────────────────


model ConsultationRequest {
  id                 Int       @id @default(autoincrement())
  publicCode         String    @unique
  claimToken         String    @unique
  source             String    @default("BALE_MINIAPP")
  status             String    @default("OPEN")
  // null هنگامی که درخواست از فرم سایت آمده باشد و متقاضی حساب بله ندارد.
  // در آن حالت واگذاری فقط تلفنی است و پیام «چت با وکیل» ارسال نمی‌شود.
  userBaleId         String?
  userBaleUsername   String?
  // توکن یک‌بارمصرفِ «پیگیری در بله» برای متقاضیِ فرم سایت. در deep-link
  // ble.ir/<bot>?start=<token> می‌نشیند و با /start حسابِ بله‌ی متقاضی را به
  // همین درخواست می‌بندد. جدا از claimToken است — آن مالِ وکیل است و اگر به
  // دست متقاضی بیفتد می‌تواند درخواست خودش را بپذیرد.
  clientLinkToken    String?   @unique
  clientName         String
  // برای source=WEB_FORM اجباری است (تنها راه تماس)، برای مینی‌اپ اختیاری.
  phone              String?
  email              String?
  preferredContact   String?
  category           String
  subCategory        String?
  city               String
  clientRole         String?
  caseStage          String
  urgency            String
  summary            String
  assignedLawyerId   Int?
  acceptedAt         DateTime?
  handoffSentAt      DateTime?
  contactedAt        DateTime?
  closedAt           DateTime?
  groupChatId        String?
  groupMessageId     String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  assignedLawyer     TeamMember?           @relation("AssignedLawyer", fields: [assignedLawyerId], references: [id], onDelete: SetNull)
  events             ConsultationEvent[]
  deliveries         NotificationDelivery[]

  @@index([status, createdAt])
  @@index([assignedLawyerId, status])
  @@index([userBaleId, createdAt])
  // نرخ‌گیری فرم سایت بر اساس شماره تماس — کاربر وب شناسه بله ندارد.
  @@index([phone, createdAt])
}

model LawyerBaleAccount {
  id                 Int       @id @default(autoincrement())
  lawyerId           Int       @unique
  baleUserId         String    @unique
  baleUsername       String?
  balePublicChatUrl  String
  isVerified         Boolean   @default(false)
  isActive           Boolean   @default(true)
  isAvailable        Boolean   @default(true)
  maxOpenRequests    Int       @default(5)
  allowedCategories  String    @default("[]")
  verifiedAt         DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  lawyer             TeamMember @relation(fields: [lawyerId], references: [id], onDelete: Cascade)

  @@index([isActive, isAvailable])
}

model LawyerBaleActivationCode {
  id          Int       @id @default(autoincrement())
  lawyerId    Int
  codeHash    String    @unique
  expiresAt   DateTime
  usedAt      DateTime?
  createdAt   DateTime  @default(now())

  lawyer      TeamMember @relation(fields: [lawyerId], references: [id], onDelete: Cascade)

  @@index([lawyerId, expiresAt])
}

model ConsultationEvent {
  id                    Int       @id @default(autoincrement())
  consultationRequestId Int
  eventType             String
  actorType             String
  actorId               String?
  metadata              String    @default("{}")
  createdAt             DateTime  @default(now())

  consultationRequest   ConsultationRequest @relation(fields: [consultationRequestId], references: [id], onDelete: Cascade)

  @@index([consultationRequestId, createdAt])
  @@index([eventType, createdAt])
}

model BaleProcessedUpdate {
  updateId      String    @id
  status        String    @default("RECEIVED")
  attemptCount  Int       @default(1)
  lastError     String?
  receivedAt    DateTime  @default(now())
  processedAt   DateTime?
}

model NotificationDelivery {
  id                    Int       @id @default(autoincrement())
  consultationRequestId Int?
  recipientType         String
  recipientId           String
  messageType           String
  dedupeKey             String    @unique
  status                String    @default("PENDING")
  attemptCount          Int       @default(0)
  lastError             String?
  sentAt                DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  consultationRequest   ConsultationRequest? @relation(fields: [consultationRequestId], references: [id], onDelete: Cascade)

  @@index([status, createdAt])
  @@index([consultationRequestId, messageType])
}
